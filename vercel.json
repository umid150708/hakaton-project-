{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "functions": {
    "api/*.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    { "path": "/api/market-refresh", "schedule": "0 1 * * *" }
  ]
}
