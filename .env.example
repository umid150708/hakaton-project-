# Copy this to .env.local and fill in your keys
# NEVER commit .env.local

# ── AI providers ──────────────────────────────────────────────────────────────

# Groq — PRIMARY for market analysis (free, 14,400 req/day)
# Sign up at: https://console.groq.com → API Keys → Create key
GROQ_API_KEY=gsk_...

# Gemini — used for AI chatbot + fallback for market analysis
# Get free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
GEMINI_API_KEY_2=AIza...   # optional 2nd key — rotated on rate limit
GEMINI_API_KEY_3=AIza...   # optional 3rd key — further triples daily quota
